{
  "name": "jsc-typescript-ast-mcp",
  "version": "1.0.9",
  "mcpName": "io.github.jscoobyced/jsc-typescript-ast-mcp",
  "description": "A Model Context Protocol (MCP) server that provides an abstract syntax tree (AST) representation of TypeScript code using the ts-morph library.",
  "main": "dist/index.js",
    "repository": {
    "type": "git",
    "url": "https://github.com/jscoobyced/jsc-typescript-ast-mcp/"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "language-server",
    "ai",
    "code-intelligence",
    "ast",
    "refactoring"
  ],
  "scripts": {
    "format": "prettier --write .",
    "build": "tsc",
    "test:mcp": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "bin": {
    "typescript-ast": "run.sh"
  },
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  }
}
